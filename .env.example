# Copy to .env and fill in real values. Never commit .env.

# MongoDB Atlas connection string for the project.
MONGO_URI=your_mongodb_atlas_uri_here

# Deprecated Hopsworks settings — no longer used after the MongoDB migration.
# HOPSWORKS_API_KEY=your_hopsworks_api_key_here
# HOPSWORKS_PROJECT=AQI_Predictor_Hyderabad

# Open-Meteo is free and requires no API key.
# Leave the lines below commented unless you need to override behaviour.
# FEATURE_STORE_MODE=parquet   # set to "parquet" to skip Hopsworks and use local .local_fs/
